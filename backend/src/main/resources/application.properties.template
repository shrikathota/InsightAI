# ============================================
# InsightAI Backend Configuration Template
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to 'application.properties'
# 2. Replace placeholder values with your actual configuration
# 3. NEVER commit application.properties to Git
# ============================================

# Server Configuration
server.port=8080

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Option 1: H2 In-Memory Database (for quick testing - NO INSTALLATION REQUIRED)
spring.datasource.url=jdbc:h2:mem:insightai_db
spring.datasource.username=sa
spring.datasource.password=
spring.datasource.driver-class-name=org.h2.Driver

# H2 Console (optional - access at http://localhost:8080/h2-console)
spring.h2.console.enabled=true
spring.h2.console.path=/h2-console

# JPA Configuration for H2
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.H2Dialect
spring.jpa.properties.hibernate.format_sql=true

# Option 2: PostgreSQL Database (uncomment when PostgreSQL is installed)
# spring.datasource.url=jdbc:postgresql://localhost:5432/insightai_db
# spring.datasource.username=YOUR_POSTGRES_USERNAME
# spring.datasource.password=YOUR_POSTGRES_PASSWORD
# spring.datasource.driver-class-name=org.postgresql.Driver
# spring.jpa.hibernate.ddl-auto=update
# spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Change this secret in production!
# Generate a secure secret: openssl rand -base64 32
jwt.secret=YOUR_JWT_SECRET_KEY_MINIMUM_256_BITS_CHANGE_IN_PRODUCTION
jwt.expiration=86400000

# ============================================
# GEMINI API CONFIGURATION
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
gemini.api.key=YOUR_GEMINI_API_KEY_HERE
gemini.api.url=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent

# ============================================
# CORS CONFIGURATION
# ============================================
cors.allowed.origins=http://localhost:3000

# ============================================
# LOGGING CONFIGURATION
# ============================================
logging.level.com.insightai=DEBUG
logging.level.org.springframework.security=DEBUG
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE
