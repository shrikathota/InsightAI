# ============================================
# InsightAI - Professional .gitignore
# ============================================

# ============================================
# SENSITIVE DATA - NEVER COMMIT
# ============================================

# Application Configuration (contains API keys & secrets)
backend/src/main/resources/application.properties
backend/src/main/resources/application.yml
backend/src/main/resources/application-*.properties
backend/src/main/resources/application-*.yml

# Environment Variables
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# API Keys & Secrets
**/secrets/
**/*secret*
**/*key*.txt
**/*credentials*.json

# ============================================
# BACKEND (Spring Boot / Maven)
# ============================================

# Maven
backend/target/
backend/pom.xml.tag
backend/pom.xml.releaseBackup
backend/pom.xml.versionsBackup
backend/pom.xml.next
backend/release.properties
backend/dependency-reduced-pom.xml
backend/buildNumber.properties
backend/.mvn/timing.properties
backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot
backend/HELP.md
backend/mvnw
backend/mvnw.cmd

# Logs
backend/logs/
backend/*.log
backend/**/*.log

# ============================================
# FRONTEND (Next.js / React)
# ============================================

# Dependencies
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js

# Testing
frontend/coverage/

# Next.js Build Output
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/

# Production
frontend/build/

# Misc
frontend/.DS_Store
frontend/*.pem

# Debug
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Local env files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Vercel
frontend/.vercel

# Typescript
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ============================================
# DATABASE
# ============================================

# H2 Database Files
*.db
*.h2.db
*.mv.db
*.trace.db

# PostgreSQL
*.sql
*.dump
*.backup

# Database Migrations (keep structure, exclude data)
**/data/
**/backups/

# ============================================
# IDE & EDITORS
# ============================================

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Eclipse
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/private/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ============================================
# OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================
# KIRO AI ASSISTANT
# ============================================

# Keep spec files but exclude temporary files
.kiro/cache/
.kiro/temp/
.kiro/.session

# ============================================
# MISCELLANEOUS
# ============================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output/

# Grunt intermediate storage
.grunt/

# Bower dependency directory
bower_components/

# node-waf configuration
.lock-wscript

# Compiled binary addons
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# parcel-bundler cache
.cache
.parcel-cache

# Next.js
.next/
out/

# Nuxt.js
.nuxt/
dist/

# Gatsby files
.cache/
public/

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp/

# Docusaurus cache and generated files
.docusaurus/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Temporary folders
tmp/
temp/

# ============================================
# PROJECT SPECIFIC
# ============================================

# Keep documentation but exclude generated docs
docs/generated/

# Keep README and setup files
!README.md
!SETUP_AND_TEST.md
!TESTING_CHECKLIST.md
!PROJECT_SUMMARY.md
!POSTMAN_COLLECTION.md
